# MongoDB Atlas connection string (get from cloud.mongodb.com)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/expertconnect

# JWT secret — use any long random string
JWT_SECRET=replace_with_a_long_random_secret_string

# Your Vercel frontend URL (set after deploying frontend)
CLIENT_URL=https://your-app.vercel.app

# Stripe secret key (optional, uses mock if not set)
STRIPE_SECRET_KEY=sk_test_...

# Port (Render sets this automatically)
PORT=5000
